{
  "buildCommand": "cd rhythm-jet-squadron && npm ci && npm run build",
  "outputDirectory": "rhythm-jet-squadron/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.joinhavn.io/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
