# HavnAI API base URL used by packaged/non-browser-hosted builds.
# For normal browser dev and deploys, keep this at /api and let the proxy/rewrite handle routing.
VITE_HAVNAI_API_BASE=/api

# Local dev proxy target for Vite. Point this at your sibling havnai-core server.
VITE_HAVNAI_PROXY_TARGET=http://127.0.0.1:5001

# Optional: override the HavnAI web URL shown in-game
VITE_HAVNAI_WEB_URL=https://joinhavn.io
