{
  "appId": "com.astravalkyries.rhythmjetsquadron",
  "productName": "Astra Valkyries",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "mac": {
    "target": [
      "dmg"
    ],
    "category": "public.app-category.games"
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
